#!/bin/bash

{{ if eq .chezmoi.os "darwin" -}}
# Install Xcode Command Line Tools if needed
if ! command -v git &> /dev/null; then
  echo "Installing Xcode Command Line Tools..."
  xcode-select --install
  echo "Waiting for Xcode CLI tools..."
  until command -v git &> /dev/null; do sleep 5; done
fi

# Install Homebrew if needed
if ! command -v brew &> /dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
{{ else -}}
# Linux: install git if missing
if ! command -v git &> /dev/null; then
  if command -v dnf &> /dev/null; then
    sudo dnf install -y git-all
  elif command -v apt-get &> /dev/null; then
    sudo apt-get install -y git
  fi
fi

if [ ! -d "$HOME/.pyenv" ] && ! command -v pyenv &> /dev/null; then
  echo "Installing pyenv..."
  curl -fsSL https://pyenv.run | bash
fi

if [ -d "$HOME/.pyenv" ] && [ ! -d "$HOME/.pyenv/plugins/pyenv-virtualenv" ]; then
  echo "Installing pyenv-virtualenv..."
  git clone https://github.com/pyenv/pyenv-virtualenv.git "$HOME/.pyenv/plugins/pyenv-virtualenv"
fi
{{ end -}}
